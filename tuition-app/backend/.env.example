PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI_PROD=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ShreeRamAcademy?retryWrites=true&w=majority

# Secret used to sign login JWTs — keep this private
JWT_SECRET=change-this-to-a-long-random-string

# Your Vercel frontend URL (for CORS, and included in welcome emails)
FRONTEND_URL=https://your-app.vercel.app

# SMTP — used to email login credentials when a new academy account is created.
# Leave unset to skip sending (account creation still works, just no email).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
